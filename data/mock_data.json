      "type": "派生指标",
      "unit": "%",
      "definition": "总资产收益率，衡量资产使用效率",
      "business_caliber": "净利润 / 平均总资产 * 100%",
      "technical_field": "finance.profit.net_profit / finance.asset.average",
      "owner": "王五",
      "department": "财务部",
      "update_time": "2024-01-15",
      "status": "已发布",
