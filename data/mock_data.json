  "metric_details": {
    "m001": {
      "id": "m001",
      "name": "净利润率",
      "type": "派生指标",
      "unit": "%",
      "definition": "净利润与营业收入的比率，反映企业盈利能力",
      "business_caliber": "归属于母公司股东的净利润 / 营业收入 * 100%",
      "technical_field": "finance.profit.net_profit / finance.revenue.operating_revenue",
      "owner": "张三",
      "department": "财务部",
      "update_time": "2024-01-15",
      "status": "已发布",
      "cycle": "月度",
      "data_source": "财务数据仓库",
      "bloodline": [
        "财务报表",
        "利润表",
        "营业收入",
        "净利润"
      ]
    },
    "m002": {
      "id": "m002",
      "name": "ROE",
      "type": "派生指标",
      "unit": "%",
      "definition": "净资产收益率，衡量股东权益回报",
      "business_caliber": "净利润 / 平均股东权益 * 100%",
      "technical_field": "finance.profit.net_profit / finance.equity.average",
      "owner": "李四",
      "department": "财务部",
      "update_time": "2024-01-15",
      "status": "已发布",
      "cycle": "季度",
      "data_source": "财务数据仓库",
      "bloodline": [
        "资产负债表",
        "利润表",
        "股东权益变动表"
      ]
    },
    "m003": {
